@namespace AppForSEII2526.Web.Components.Shared

<div class="modal fade show" id="DialogOKSaveDelete" style="display:block; background-color: rgba(10,10,10,.8);" aria-modal="true" role="dialog">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h4 class="modal-title">@Caption</h4>
                <button type="button" class="close"
                        @onclick="@Cancel">
                    &times;
                </button>
            </div>
            <div class="modal-body">
                <p>@Message</p>
            </div>
            <div class="modal-footer">
                @switch (Type)
                {
                    case Category.Okay:
                        <button type="button" class="btn btn-primary" @onclick=@Ok id="Button_DialogOK">
                            OK
                        </button>
                        break;
                    case Category.SaveNot:
                        <button type="button" class="btn btn-primary" @onclick=@Ok id="Button_DialogOK">
                            Save
                        </button>
                        <button type="button" class="btn btn-warning" @onclick="@Cancel" id="Button_DialogCancel">
                            Don't Save
                        </button>
                        break;
                    case Category.DeleteNot:
                        <button type="button" class="btn btn-danger" @onclick=@Ok id="Button_DialogOK">
                            Delete
                        </button>
                        <button type="button" class="btn btn-warning" @onclick="@Cancel" id="Button_DialogCancel">
                            Don't Delete
                        </button>
                        break;
                }
            </div>
        </div>
    </div>
</div>

@code {
    // Título de la ventana modal
    [Parameter] public string Caption { get; set; } = string.Empty;

    // Mensaje a mostrar en el cuerpo del diálogo
    [Parameter] public string Message { get; set; } = string.Empty;

    // Se invoca con true (OK/Save/Delete) o false (Cancel/Don't Save/Don't Delete)
    [Parameter] public EventCallback<bool> OnClose { get; set; }

    // Tipo de diálogo (define texto y estilo de botones)
    [Parameter] public Category Type { get; set; }

    private Task Cancel()
    {
        // Usuario cancela la operación
        return OnClose.InvokeAsync(false);
    }

    private Task Ok()
    {
        // Usuario confirma la operación
        return OnClose.InvokeAsync(true);
    }

    public enum Category
    {
        Okay,
        SaveNot,
        DeleteNot
    }
}
