@page "/Review/selectDeviceForReview"

@using AppForSEII2526.Web.OpenAPI
@using System
@inject AppForSEII2526APIClient apiclient
@inject ILogger<SelectDevicesForReview> logger
@inject ReviewStateContainer reviewState
@inject NavigationManager navigation

<h3>Select Devices For Review</h3>

<div class="container-fluid">
    <div class="row" hidden="@HideErrors">
        <p>@Errors</p>
    </div>
    <div class="row">
        <div class="col-8">
            <div class="row">
                <div class="col">
                    <div class="input-group mb-3">
                        <span class="input-group-text" id="basic-addon1">Brand</span>
                        <input type="text" id="inputBrand" @bind=deviceBrand class="form-control" placeholder="Brand" aria-label="Brand" aria-describedby="basic-addon1">
                    </div>
                </div>
                <div class="col">
                    <div class="input-group mb-3">
                        <span class="input-group-text" id="basic-addon1">Year</span>
                        <input type="text" id="inputYear" @bind=deviceYear class="form-control" placeholder="Year" aria-label="Year" aria-describedby="basic-addon1">
                    </div>
                </div>
                <div class="col">
                    <button type="button"
                            class="btn btn-primary"
                            @onclick=@SearchDevices
                            id="searchDevices">
                        Search devices
                    </button>
                </div>
            </div>
            <div class="row">
                @if (devices == null)
                {
                    <p>Loading devices....</p>
                }
                else
                {
                    <div class="mh-100 table-responsive">
                        <table class="table table-condensed table-hover" id="TableOfDevices">
                            <thead>
                                <tr>
                                    <th>Brand</th>
                                    <th>Color</th>
                                    <th>Name</th>
                                    <th>Year</th>
                                    <th>Model</th>
                                    <th>Añadir a carrito</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var device in devices)
                                {
                                    <tr id="DeviceData_@device.Id">
                                        <td>@device.Brand</td>
                                        <td>@device.Color</td>
                                        <td>@device.Name</td>
                                        <td>@GetDeviceYear(device)</td>
                                        <td>@device.Model</td>
                                        <td>
                                            <button class="btn btn-outline-secondary" id="deviceToReview_@device.Id" @onclick="@(() => AddDevice(device))">Add</button>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>

                }
            </div>
        </div>
        <div class="col-2" hidden="@HideCart">
            <div class="row">
                <button class="btn btn-outline-primary" id="showReviewCart" @onclick="@ToggleReviewCart">@(hideReviewCart ? "Mostrar" : "Ocultar")</button>
            </div>
            @foreach (ReviewItemForCreateDTO item in review.ReviewItems)
            {
                <div class="row">
                    <button type="button" class="btn btn-light" id="removeDevice_@item.DeviceId" @onclick="@(() => RemoveReviewItem(item))">Device @item.DeviceId</button>
                </div>
            }
            <div class="row">
                <button type="button" class="btn btn-primary" id="DevicesReviewButton" @onclick=@ReviewDevices>Review</button>
            </div>
        </div>

    </div>

</div>

@code {
    private string debugJson = "";

    private IList<ReviewItemDTO>? devices;
    private List<string> brands = new();
    private List<string> years = new();

    private string deviceBrand = "";
    private string deviceYear = "";
    
    private string filterName = "";
    private string filterBrand = "All";
    private string filterYear = "All";

    private string Errors = "";
    private bool HideErrors => string.IsNullOrEmpty(Errors);
    private bool hideReviewCart = false;

    private ReviewForCreateDTO review => reviewState.Review;
    private bool HideCart => review.ReviewItems.Count == 0;

    // Método auxiliar para acceder a la propiedad year
    private int GetDeviceYear(ReviewItemDTO device)
    {
        var yearProperty = device.GetType().GetProperty("year");
        if (yearProperty != null)
        {
            return (int)yearProperty.GetValue(device);
        }
        return 0;
    }

    protected override async Task OnInitializedAsync()
    {
        try
        {
            devices = (await apiclient.GetDevicesForReviewAsync()).ToList();

            var options = new System.Text.Json.JsonSerializerOptions 
            { 
                WriteIndented = true,
                PropertyNamingPolicy = System.Text.Json.JsonNamingPolicy.CamelCase
            };
            debugJson = System.Text.Json.JsonSerializer.Serialize(devices, options);

            brands = devices
                .Select(d => d.Brand)
                .Distinct()
                .OrderBy(b => b)
                .ToList();

            years = devices
                .Select(d => GetDeviceYear(d).ToString())
                .Distinct()
                .OrderBy(y => y)
                .ToList();
        }
        catch (System.Exception ex)
        {
            Errors = "Error loading devices.";
            logger.LogError(ex, "Error al cargar dispositivos");
        }
    }

    private void AddDevice(ReviewItemDTO d)
    {
        reviewState.AddDeviceToReview(d);
    }

    private void RemoveReviewItem(ReviewItemForCreateDTO item)
    {
        reviewState.RemoveDeviceFromReview(item);
    }

    private void ToggleReviewCart()
    {
        hideReviewCart = !hideReviewCart;
    }

    private void ReviewDevices()
    {
        navigation.NavigateTo("/review/createReview");
    }

    private async Task SearchDevices()
    {
        try
        {
            devices = (await apiclient.GetDevicesForReviewAsync()).ToList();

            if (!string.IsNullOrWhiteSpace(deviceBrand))
                devices = devices
                    .Where(d => d.Name.Contains(deviceBrand, StringComparison.OrdinalIgnoreCase))
                    .ToList();


            if (!string.IsNullOrWhiteSpace(deviceYear) && int.TryParse(deviceYear, out int year))
                devices = devices
                    .Where(d => GetDeviceYear(d) == year)
                    .ToList();  

            Errors = "";
        }
        catch (System.Exception ex)
        {
            Errors = "Error searching devices.";
            logger.LogError(ex, "Error al buscar dispositivos");
        }
    }
}
