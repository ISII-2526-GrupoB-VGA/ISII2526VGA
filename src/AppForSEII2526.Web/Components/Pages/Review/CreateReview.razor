@page "/review/createReview"
@inject NavigationManager navigation
@using AppForSEII2526.Web.Components.Shared
@using AppForSEII2526.Web.OpenAPI
@using Microsoft.AspNetCore.Authorization
@inject AppForSEII2526APIClient apiclient
@inject ILogger<CreateReview> logger
@inject ReviewStateContainer reviewState

@* @attribute [Authorize] *@

<h3>Create Review</h3>

@* review is the object that will be edited thanks to the form *@
<EditForm Model="review" OnValidSubmit="OpenDialog">
    <div class="row">
        <DataAnnotationsValidator />
        <ValidationSummary class="row alert alert-danger" />
    </div>
    <div class="row alert alert-danger" role="alert" hidden="@hideErrors">
        <p id="ErrorsShown">Errors: @messageError</p>
    </div>
    <div class="row g-3">
        <div class="col-md">
            <div class="form-floating mb-3">
                <InputText @bind-Value="review.CustomerName" class="form-control" id="CustomerName" />
                <label for="CustomerName">Customer Name</label>
            </div>
        </div>
        <div class="col-md">
            <div class="form-floating mb-3">
                <InputText @bind-Value="review.CustomerCountry" class="form-control" id="CustomerCountry" />
                <label for="CustomerCountry">Customer Country</label>
            </div>
        </div>
        <div class="col-md">
            <div class="form-floating mb-3">
                <InputText @bind-Value="review.ReviewTitle" class="form-control" id="ReviewTitle" />
                <label for="ReviewTitle">Review Title</label>
            </div>
        </div>
    </div>
    <div class="row g-2">
        <div class="col-md">
            <div class="form-floating">
                @*this button will be used to ask the user if he want to proceed to create the review*@
                <button class="btn btn-primary" type="submit" id="Submit" disabled="@reviewButtonDisabled">
                    Submit your review
                </button>
            </div>  
        </div>
    </div>
    <h4>Review detail</h4>
    <p><b>Date:</b> @DateTime.Now.ToString("dd/MM/yyyy")</p>
    <p>
        <b>Overall Rating:</b> @CalculateOverallRating().ToString("F1") / 5.0
        <button class="btn btn-outline-primary" type="button" @onclick="ModifyReviewItems" id="ModifyDevices">
            Modify devices
        </button>
    </p>
    
    <div class="mh-100 table-responsive">
        <table class="table table-condensed table-hover" id="TableOfReviewItems">
            <thead>
                <tr>
                    <th>Device ID</th>
                    <th>Rating</th>
                    <th>Comment</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in review.ReviewItems) {
                    <tr id="DeviceData_@item.DeviceId">
                        <td>@item.DeviceId</td>
                        <td>
                            <InputNumber @bind-Value="item.Rating" class="form-control" id="@($"rating_{item.DeviceId}")" min="0" max="5" step="0.1" />
                        </td>
                        <td>
                            <InputText @bind-Value="item.Comment" class="form-control" id="@($"comment_{item.DeviceId}")" />
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</EditForm>

@*a modal popup dialog for checking if user wants to proceed to create review*@
@if (DialogIsOpen)
{
    <Dialog Caption="Create Review"
    Message="Do you want to proceed to submit this review?"
    OnClose="@OnDialogClose"
    Type=Dialog.Category.SaveNot>
    </Dialog>
}

@code {
    private string messageError = "";
    private bool hideErrors { get { return messageError.Length == 0; } }

    // Botón deshabilitado si no hay dispositivos en el carrito de review
    private bool reviewButtonDisabled { get { return (review.ReviewItems == null || review.ReviewItems.Count == 0); } }

    private bool DialogIsOpen;

    // Referencia al review desde el estado compartido
    private ReviewForCreateDTO review => reviewState.Review;

    private void OpenDialog()
    {
        DialogIsOpen = true;
    }


    private void ModifyReviewItems() //Navega a la página para modificar los dispositivos de la review
    {
        navigation.NavigateTo("/review/selectDeviceForReview");
    }

    private float CalculateOverallRating() //Calcula la valoración global como la media de las valoraciones de los dispositivos
    { //Ns si esto debe estar...
        if (review.ReviewItems == null || review.ReviewItems.Count == 0)
            return 0;

        return review.ReviewItems.Average(item => item.Rating);
    }

    private async Task OnDialogClose(bool isOk) //isOk, es que el usuario ha pulsado aceptar
    {
        DialogIsOpen = false;
        if (isOk)
        {
            //Comrpueba q los daros q ha metido el usuario son correctos
            if (review.ReviewItems.Count > 0)
            {
                try
                {

                    var reviewed = await apiclient.CreateReviewAsync(review); //Lanza la petición a la API para crear la review
                    reviewState.ClearReview(); //Limpia el estado compartido #Creo q así debe furular
                    navigation.NavigateTo($"/review/detailreview?ReviewID={reviewed.Id}"); //Navega a la página de detalle de la review creada
                }
                catch (ApiException<ValidationProblemDetails> apiexceptionvalidation) //Captura errores de validación
                {
                    if (apiexceptionvalidation.Result.Errors.Values != null)
                    {
                        messageError = "";
                        foreach ( var errors in apiexceptionvalidation.Result.Errors.Values)
                        {
                            //https://learn.microsoft.com/en-us/dotnet/api/system.string.join?view=net-7.0 //Ns q pollas es, pero seguro q me sirve luiego
                            messageError = string.Join("(*) ", messageError, string.Join(" (*)", errors));
                        }
                    }
                }
                catch (ApiException apiexception)
                {
                    messageError = "Error al procesar review. prueba luego. Y de pronto supe cual es la razón, al menos unas pocas horas";
                }
            }
        }
    }

    protected override Task OnInitializedAsync()
    {
        return Task.CompletedTask;
    }




}
