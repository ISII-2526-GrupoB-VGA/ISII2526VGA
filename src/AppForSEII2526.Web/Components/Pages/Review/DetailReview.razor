@page "/review/Detailreview"

@using Microsoft.AspNetCore.Authorization
@using AppForSEII2526.Web.OpenAPI
@inject AppForSEII2526APIClient apiclient
@inject ReviewStateContainer reviewState
@inject NavigationManager navigation

<h3>DetailReview</h3>

@if (review == null)
{
    <p>@error</p>
}
else
{
    <table class="table table-borderless table-sm">
        <tr>
            <th>Customer Name</th>
            <td id="CustomerName">@(review.CustomerName ?? "N/A")</td>
        </tr>
        <tr>
            <th>Country</th>
            <td id="CustomerCountry">@review.CustomerCountry</td>
        </tr>
        <tr>
            <th>Review Title</th>
            <td id="ReviewTitle">@review.ReviewTitle</td>
        </tr>
        <tr>
            <th>Date of Review</th>
            <td id="DateOfReview">@review.DateOfReview.ToString("dd/MM/yyyy HH:mm:ss")</td>
        </tr>
        <tr>
            <th>Overall Rating</th>
            <td id="OverallRating">@review.OverallRating.ToString("F2") / 5.0</td>
        </tr>
    </table>

    <h4>Reviewed Devices</h4>

    <table class="table" id="ReviewedDevices">
        <thead>
            <tr>
                <th scope="col">Name</th>
                <th scope="col">Model</th>
                <th scope="col">Year</th>
                <th scope="col">Rating</th>
                <th scope="col">Comment</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in review.ReviewItems)
            {
                <tr id="ReviewItem_@item.DeviceId">
                    <td>@item.DeviceName</td>
                    <td>@item.DeviceModel</td>
                    <td>@item.DeviceYear</td>
                    <td>@item.Rating / 5.0</td>
                    <td>@item.Comment</td>
                </tr>
            }
        </tbody>
    </table>
}

@code {

    [Parameter]
    [SupplyParameterFromQuery]
    public int ReviewID { get; set; }
    private ReviewDetailDTO review;
    private string error = "";


    // https://localhost:7081/review/Detailreview/?ReviewID=3
    //Esa es la URL para ver las reviews


    // [CascadingParameter]
    // private Task<AuthenticationState>? authenticationState { get; set; } //Estas 2 seguramente no debo ponerlas

    protected override async Task OnInitializedAsync()
    {
        try
        {
            review = await apiclient.GetReviewAsync(ReviewID);
        }
        catch(ApiException)
        {
            error = "Error loading review details.";
        }

    }


}